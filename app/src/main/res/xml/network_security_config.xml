<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Trust system CAs for all Android versions (API 24+).
        This ensures SSL connections work correctly on all supported devices,
        including those with custom ROMs or older system trust stores.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust the device's built-in system Certificate Authorities -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only for localhost during development/testing -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.deepseek.com</domain>
        <domain includeSubdomains="true">api.openai.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
